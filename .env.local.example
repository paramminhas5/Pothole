# ============================================
# SAHAYATA PLATFORM — Environment Variables
# ============================================

# Supabase Configuration
# Get these from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin secret for moderation panel access (/admin)
ADMIN_SECRET=change-this-to-a-strong-secret

# Email (Resend) — for OTP verification and response notifications
# Sign up at https://resend.com (free tier: 100 emails/day)
# Leave empty for development (emails logged to console instead)
RESEND_API_KEY=re_your-resend-api-key
FROM_EMAIL=Sahayata <noreply@yourdomain.com>
