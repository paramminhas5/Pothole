# ============================================
# SAHAYATA PLATFORM — Environment Variables
# ============================================

# Supabase Configuration
# Get these from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Server-only signing secret (at least 32 random characters; never expose in NEXT_PUBLIC_*)
SESSION_SIGNING_SECRET=replace-with-at-least-32-random-characters

# Temporary moderation bootstrap password (at least 24 random characters).
# The browser exchanges this once for a signed, HttpOnly 12-hour session cookie.
# Replace with named moderator accounts + MFA before a public pilot.
ADMIN_SECRET=replace-with-at-least-24-random-characters

# Email (Resend) — for OTP verification and response notifications
# Sign up at https://resend.com (free tier: 100 emails/day)
# Leave empty for development (emails logged to console instead)
RESEND_API_KEY=re_your-resend-api-key
FROM_EMAIL=Sahayata <noreply@yourdomain.com>
